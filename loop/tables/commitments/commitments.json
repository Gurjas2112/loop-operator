    { "name": "times_recommitted", "type": "INTEGER", "default": 1 },
    { "name": "current_status", "type": "ENUM", "default": "open", "options": ["open", "done", "dropped"] },
    { "name": "is_reversed", "type": "BOOLEAN", "default": false }
  ],
  "config": {}
}
