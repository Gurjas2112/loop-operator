// librarian — the MEMORY curator. Distils durable facts after a meeting and calls memory_write.
// Grants include the function-tool set for memory_write (read+execute) + its mirrored grants.
// Runtime is swappable via an OpenAI-compatible profile (see scripts/setup-open-model.md):
//   - Local open model (default, zero-cost): run scripts/register-open-model.py, e.g. qwen2.5:*-instruct
//   - Hosted GPT-5.5: create the profile, then set the block below.
//   "agent_runtime": { "profile_id": "<openai-compatible-profile-id>", "model_name": "qwen2.5:7b-instruct" },
{
  "name": "librarian",
  "description": "After a meeting is ready, distil DURABLE facts (roles, chronic-slip patterns, norms, key decisions) into long-term memory via memory_write.",
  "instruction": { "$file": "instruction.md" },
  "toolsets": ["POD"],
  "permissions": {
    "grants": [
      { "resource_type": "datastore_table", "resource_name": "meetings", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "action_items", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "commitments", "permission_ids": ["datastore.table.read", "datastore.record.read"] },
      { "resource_type": "datastore_table", "resource_name": "memory", "permission_ids": ["datastore.table.read", "datastore.record.read", "datastore.record.write"] },
      { "resource_type": "datastore_table", "resource_name": "metrics", "permission_ids": ["datastore.table.read", "datastore.record.write"] },
      { "resource_type": "folder", "resource_name": "/memory", "permission_ids": ["folder.read", "folder.write"] },
      { "resource_type": "function", "resource_name": "memory_write", "permission_ids": ["function.read", "function.execute"] }
    ]
  }
}
